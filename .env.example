# ── NarrativeCare AI — API Keys ───────────────────────────────────────────────
# Copy this file to .env:  copy .env.example .env   (Windows)  or  cp .env.example .env   (Mac/Linux)
# Fill in your keys below. Never commit .env to git.

# ── REQUIRED FOR STORY GENERATION ─────────────────────────────────────────────
# Get from: platform.openai.com → API keys
OPENAI_API_KEY=your_openai_key_here

# ── REQUIRED FOR VIDEO (add when Person 3 is ready) ──────────────────────────
# Get from: klingai.com → API → Keys (free credits on signup)
KLING_API_KEY=your_kling_key_here
KLING_API_SECRET=your_kling_secret_here

# ── REQUIRED FOR AUDIO (add when Person 3 is ready) ──────────────────────────
# Get from: elevenlabs.io → Profile → API Key (free tier works)
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── IBM STACK (Person 4 fills these in) ──────────────────────────────────────
IBM_API_KEY=your_ibm_api_key_here
IBM_PROJECT_ID=your_ibm_project_id_here
IBM_DB2_DSN=your_db2_connection_string_here
